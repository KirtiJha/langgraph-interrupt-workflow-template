# ─────────────────────────────────────────────────────────────
#  LLM configuration (provider-agnostic via langchain init_chat_model)
# ─────────────────────────────────────────────────────────────
# Pick ANY provider. Leave everything unset to run with the built-in
# zero-config mock model.
#
# Examples:
#   OpenAI:     LLM_MODEL=gpt-4o-mini          + OPENAI_API_KEY
#   Anthropic:  LLM_MODEL=claude-sonnet-4-5    + ANTHROPIC_API_KEY  (LLM_PROVIDER=anthropic)
#   Google:     LLM_MODEL=gemini-2.0-flash     + GOOGLE_API_KEY     (LLM_PROVIDER=google_genai)
#   Ollama:     LLM_MODEL=llama3.1             + (LLM_PROVIDER=ollama)
#   IBM watsonx:LLM_MODEL=meta-llama/llama-3-3-70b-instruct + WATSONX_* (LLM_PROVIDER=ibm)

LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=openai
LLM_TEMPERATURE=0.7

# Provider API keys (set the one matching your model)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# IBM watsonx (only if LLM_PROVIDER=ibm)
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_API_KEY=
# WATSONX_PROJECT_ID=

# Force the offline mock model regardless of the above
# USE_MOCK_LLM=true

# ─────────────────────────────────────────────────────────────
#  Tools (optional)
# ─────────────────────────────────────────────────────────────
# TAVILY_API_KEY=        # enables live web search in tools.py

# ─────────────────────────────────────────────────────────────
#  MCP tools (optional) — Model Context Protocol
# ─────────────────────────────────────────────────────────────
# Load tools from any MCP server and expose them to the agent (HITL-gated).
# Requires: pip install langchain-mcp-adapters
# Set to inline JSON or a path to a JSON file. Examples:
#   MCP_SERVERS='{"math": {"command": "python", "args": ["math_server.py"], "transport": "stdio"}}'
#   MCP_SERVERS=./mcp_servers.json
# MCP_SERVERS=

# ─────────────────────────────────────────────────────────────
#  Guardrails (safety middleware) — on by default, no deps
# ─────────────────────────────────────────────────────────────
# GUARDRAILS_ENABLED=true          # master switch (default: true)
# GUARDRAILS_REDACT_PII=true       # mask emails/phones/cards/SSNs before the model
# GUARDRAILS_BLOCKLIST=            # comma-separated phrases to refuse, e.g. exploit,malware

# ─────────────────────────────────────────────────────────────
#  Structured output (optional) — agent returns a typed summary
# ─────────────────────────────────────────────────────────────
# Requires a real (non-mock) model. The agent returns a validated
# ResearchSummary object in state["structured_response"].
# AGENT_STRUCTURED_OUTPUT=false

# ─────────────────────────────────────────────────────────────
#  Semantic long-term memory (optional)
# ─────────────────────────────────────────────────────────────
# Set an embeddings model to recall the most *relevant* memories (not just the
# most recent). Falls back to plain recency-based recall when unset.
#   EMBEDDINGS_MODEL=openai:text-embedding-3-small
#   EMBEDDING_DIMS=1536

# ─────────────────────────────────────────────────────────────
#  Agent middleware power-pack (prebuilt LangChain middleware)
# ─────────────────────────────────────────────────────────────
# Sensible defaults are on; thresholds are high enough to never trigger in a
# short chat. Set any value to 0/empty to disable that piece.
# AGENT_SUMMARIZATION=true                 # summarize old messages on long threads
# AGENT_SUMMARIZATION_TRIGGER_MESSAGES=40  # summarize once history exceeds this
# AGENT_SUMMARIZATION_KEEP_MESSAGES=20     # keep this many recent messages
# AGENT_MODEL_CALL_LIMIT=25                # cap model calls per run (runaway/cost guard)
# AGENT_TOOL_CALL_LIMIT=                   # cap tool calls per run (opt-in)
# AGENT_MODEL_RETRY=true                   # retry transient model errors (backoff)
# AGENT_MODEL_RETRIES=2
# AGENT_TODO_LIST=false                    # give the agent a write_todos planning tool
# AGENT_FALLBACK_MODEL=                    # fall back to this model on failure, e.g. gpt-4o-mini

# ─────────────────────────────────────────────────────────────
#  Workflow resilience (LangGraph 1.2)
# ─────────────────────────────────────────────────────────────
# LLM-backed nodes retry transient errors and degrade gracefully on failure.
# RETRY_MAX_ATTEMPTS=3                      # per-node retry attempts (transient errors)
# NODE_TIMEOUT_SECONDS=                     # per-node wall-clock timeout (empty = off)

# ─────────────────────────────────────────────────────────────
#  Persistence & server
# ─────────────────────────────────────────────────────────────
# Set a path to enable durable, resumable state across restarts.
# Leave unset for in-memory state.
# CHECKPOINT_DB=checkpoints.sqlite
PORT=8000
CORS_ORIGINS=*
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
#  Observability (optional) — LangSmith tracing
# ─────────────────────────────────────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=langgraph-interrupt-template
